{
  "name": "girl-ai-agent-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "sync:contracts:app": "node ./scripts/export-app-contracts.mjs",
    "check:contracts:app": "node ./scripts/export-app-contracts.mjs --check",
    "dev:web": "pnpm --dir apps/web/console dev",
    "dev:app": "cargo tauri dev --manifest-path apps/app/Cargo.toml",
    "build:web": "pnpm --dir apps/web/console build",
    "build:app": "cargo tauri build --manifest-path apps/app/Cargo.toml",
    "run:web-server": "cargo run -p girl-ai-agent-web-server",
    "verify:headless": "pwsh -NoProfile -Command \"& './scripts/verify-headless.ps1' -Mode smoke\"",
    "verify:headless:smoke": "pwsh -NoProfile -Command \"& './scripts/verify-headless.ps1' -Mode smoke\"",
    "verify:headless:full": "pwsh -NoProfile -Command \"& './scripts/verify-headless.ps1' -Mode full\"",
    "verify:headless:full:no-stream": "pwsh -NoProfile -Command \"& './scripts/verify-headless.ps1' -Mode full -VerifyStream:$false\"",
    "verify:headless:full:abort": "pwsh -NoProfile -Command \"& './scripts/verify-headless.ps1' -Mode full -VerifyStreamAbort\"",
    "verify:headless:summary": "node ./scripts/collect-verify-results.mjs",
    "verify:headless:running": "pwsh -NoProfile -Command \"& './scripts/verify-headless.ps1' -Mode smoke -NoStartServer\"",
    "verify:headless:ci": "pwsh -NoProfile -Command \"& './scripts/verify-headless.ps1' -Mode smoke -PrintResultJson\"",
    "check:rust": "cargo check --workspace",
    "check:web-server": "cargo check -p girl-ai-agent-web-server",
    "check:app": "cargo check -p girl-ai-agent-app",
    "moon:check": "moon run web-server:check && moon run app:check"
  },
  "devDependencies": {
    "@moonrepo/cli": "^1.30.6"
  }
}

