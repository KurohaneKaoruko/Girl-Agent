{
  "name": "girlagent-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev:web": "pnpm --dir apps/web/console dev",
    "dev:desktop": "cargo tauri dev --manifest-path apps/desktop/app/Cargo.toml",
    "build:web": "pnpm --dir apps/web/console build",
    "build:desktop": "cargo tauri build --manifest-path apps/desktop/app/Cargo.toml",
    "run:web-server": "cargo run -p girlagent-web-server",
    "check:rust": "cargo check --workspace",
    "check:web-server": "cargo check -p girlagent-web-server",
    "check:desktop": "cargo check -p girlagent-desktop",
    "moon:check": "moon run web-server:check && moon run desktop:check"
  },
  "devDependencies": {
    "@moonrepo/cli": "^1.30.6"
  }
}
